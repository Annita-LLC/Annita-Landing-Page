# ============================================================================
# FORTUNE 500 / PENTAGON-GRADE LANDING PAGE ENVIRONMENT VARIABLES
# ============================================================================

# Application Configuration
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_APP_URL=https://an-nita.com
NEXT_PUBLIC_API_URL=https://annita-landing-page-production.up.railway.app

# Security Configuration
REDIS_PASSWORD=
JWT_SECRET=

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_BURST_LIMIT=150

# IP Reputation Configuration
IP_REPUTATION_SUSPICIOUS_THRESHOLD=3
IP_REPUTATION_MALICIOUS_THRESHOLD=5
IP_REPUTATION_BLOCK_THRESHOLD=10

# Trusted Origins (comma-separated)
TRUSTED_ORIGINS=https://an-nita.com,https://www.an-nita.com,https://annita-landing-page-production.up.railway.app

# Monitoring and Logging
LOG_LEVEL=info
ENABLE_SECURITY_LOGGING=true
ENABLE_PERFORMANCE_LOGGING=true

# Feature Flags
ENABLE_BOT_DETECTION=true
ENABLE_RATE_LIMITING=true
ENABLE_IP_REPUTATION=true
ENABLE_REQUEST_VALIDATION=true
ENABLE_BEHAVIORAL_ANALYSIS=true

# IP Reputation Configuration
IP_REPUTATION_SUSPICIOUS_THRESHOLD=3
IP_REPUTATION_MALICIOUS_THRESHOLD=5
IP_REPUTATION_BLOCK_THRESHOLD=10
IP_REPUTATION_WINDOW_MS=86400000
IP_REPUTATION_DECAY_RATE=3600000

# Behavioral Analysis Configuration
BEHAVIORAL_MIN_SECONDS_BETWEEN_SUBMISSIONS=2
BEHAVIORAL_MAX_SUBMISSIONS_PER_MINUTE=10
BEHAVIORAL_MAX_FIELD_LENGTH=10000

# Email Configuration (Resend)
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=annita@an-nita.com
ADMIN_EMAIL=info@an-nita.com
ENTERPRISE_EMAIL=sales@an-nita.com
SOLUTIONS_EMAIL=solutions@an-nita.com

# Maintenance System Configuration
MAINTENANCE_SCHEDULE_DAY=SUNDAY
MAINTENANCE_SCHEDULE_TIME=02:00
MAINTENANCE_TIMEZONE=UTC
ADMIN_REPORT_TIME=09:00
ADMIN_REPORT_TIMEZONE=UTC
ADMIN_EMERGENCY_SHUTDOWN=false
