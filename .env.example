# ============================================================================
# FORTUNE 500 / PENTAGON-GRADE LANDING PAGE ENVIRONMENT VARIABLES
# ============================================================================

# Application Configuration
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_APP_URL=https://an-nita.com
NEXT_PUBLIC_API_URL=https://api.an-nita.com

# Security Configuration
REDIS_PASSWORD=
JWT_SECRET=

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_BURST_LIMIT=150

# IP Reputation Configuration
IP_REPUTATION_SUSPICIOUS_THRESHOLD=3
IP_REPUTATION_MALICIOUS_THRESHOLD=5
IP_REPUTATION_BLOCK_THRESHOLD=10

# Trusted Origins (comma-separated)
TRUSTED_ORIGINS=https://an-nita.com,https://www.an-nita.com,http://localhost:3000,http://localhost:8080

# Monitoring and Logging
LOG_LEVEL=info
ENABLE_SECURITY_LOGGING=true
ENABLE_PERFORMANCE_LOGGING=true

# Feature Flags
ENABLE_BOT_DETECTION=true
ENABLE_RATE_LIMITING=true
ENABLE_IP_REPUTATION=true
ENABLE_REQUEST_VALIDATION=true
