# ============================================================================
# ANNITA LANDING PAGE SERVER - ENVIRONMENT VARIABLES
# ============================================================================
# Fortune 500 / Pentagon Grade Configuration
# ============================================================================

# ----------------------------------------------------------------------------
# SERVER CONFIGURATION
# ----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION (Prisma Cloud)
# ----------------------------------------------------------------------------
# Prisma Cloud PostgreSQL Database
DATABASE_URL="postgresql://user:password@host:5432/annita_landing?schema=public"

# Prisma Accelerate (Optional - for connection pooling)
PRISMA_ACCELERATE_URL=""

# ----------------------------------------------------------------------------
# SECURITY CONFIGURATION
# ----------------------------------------------------------------------------
# JWT Secret for API authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# CORS Configuration
CORS_ORIGIN="https://an-nita.com,https://www.an-nita.com"
CORS_CREDENTIALS="true"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_BURST_LIMIT=150

# ----------------------------------------------------------------------------
# LOGGING CONFIGURATION
# ----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_MAX_SIZE=20m
LOG_MAX_FILES=14d

# ----------------------------------------------------------------------------
# MONITORING & OBSERVABILITY
# ----------------------------------------------------------------------------
# Sentry (Optional - for error tracking)
SENTRY_DSN=""
SENTRY_ENVIRONMENT=development

# ----------------------------------------------------------------------------
# RAILWAY DEPLOYMENT
# ----------------------------------------------------------------------------
# Railway automatically provides these, but you can override
RAILWAY_ENVIRONMENT=development
RAILWAY_PROJECT_NAME=annita-landing-page
RAILWAY_SERVICE_NAME=server

# ----------------------------------------------------------------------------
# FEATURE FLAGS
# ----------------------------------------------------------------------------
FEATURE_ENABLE_ANALYTICS=true
FEATURE_ENABLE_CONTACT_SUBMISSION=true
FEATURE_ENABLE_NEWSLETTER=true

# ----------------------------------------------------------------------------
# GOOGLE SHEETS INTEGRATION
# ----------------------------------------------------------------------------
# Google Sheets ID from the spreadsheet URL
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Full stringified JSON content of the downloaded service account key
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"annita-sheets-writer@annita-landing-page-forms.iam.gserviceaccount.com"}

# ----------------------------------------------------------------------------
# MAINTENANCE SYSTEM CONFIGURATION
# ----------------------------------------------------------------------------
# Maintenance Schedule (Sunday at configured time)
MAINTENANCE_SCHEDULE_DAY=SUNDAY
MAINTENANCE_SCHEDULE_TIME=02:00
MAINTENANCE_TIMEZONE=UTC

# Admin Health Report Schedule (Daily at 9 AM)
ADMIN_REPORT_TIME=09:00
ADMIN_REPORT_TIMEZONE=UTC

# Emergency Shutdown (set to 'true' to disable all admin access)
ADMIN_EMERGENCY_SHUTDOWN=false

