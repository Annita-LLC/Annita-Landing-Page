{
  "name": "annita-landing-page-server",
  "version": "1.0.0",
  "description": "🏆 Fortune 500 Enterprise Server for Annita Landing Page",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "npx prisma generate && node --import=tsx src/index.ts",
    "dev": "tsx --watch src/index.ts",
    "build": "npx prisma generate && echo 'Prisma client generated'",
    "build:deploy": "npx dotenv-cli -e .env -- npx prisma generate && echo 'Prisma client generated'",
    "lint": "echo 'Linting not yet implemented'",
    "health": "curl -f http://localhost:3001/health || exit 1",
    "migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "docker:build": "docker build -t annita-landing-server .",
    "docker:run": "docker run -p 3001:3001 annita-landing-server",
    "security:check": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^5.20.0",
    "@prisma/client": "^5.20.0",
    "@prisma/extension-accelerate": "^3.0.0",
    "@react-email/render": "^2.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "googleapis": "^140.0.0",
    "helmet": "^7.1.0",
    "pg": "^8.11.0",
    "resend": "^3.5.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.0",
    "prisma": "^5.20.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "overrides": {
    "@hono/node-server": "1.19.13"
  },
  "keywords": [
    "api",
    "landing-page",
    "enterprise",
    "express",
    "typescript",
    "fortune500"
  ],
  "author": "Annita LLC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Annita-LLC/Annita-v1.git"
  },
  "main": "src/index.ts",
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  }
}
