# ------------------------------------------------------------------------------
# 1. Credentials, Secrets & Sensitive Configuration Files
# ------------------------------------------------------------------------------
# Prevent any and all credential/secret leakages
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production.local
.env.staging
.env.staging.local
*.env
*.env.*
# Exclusions (Only allow tracking non-sensitive environment templates if desired)
!.env.example
# Keep the production env public references if required, but block any other production env
!.env.production

# Private Keys, Certificates, and Cryptographic credentials
*.pem
*.key
*.pub
